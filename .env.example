# 统一入口会从 .env 读取 AI、浏览器与日志相关配置。
# 复制本文件为 .env 后，再填入你自己的真实参数。

# OpenAI 兼容 API 地址
OPENAI_COMPLETION_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# OpenAI 兼容 API Key
OPENAI_COMPLETION_API_KEY=your_api_key_here

# 使用的模型名称
MODEL_NAME=qwen3.6-plus

# AI 请求类型（可选值：chat / responses）
AI_REQUEST_TYPE=responses

# 可选：为 AI 考试启用联网搜索（0/1）；联网搜索，默认关闭；chat / responses 两种请求方式都支持，需要时取消注释
# AI_ENABLE_WEB_SEARCH=1

# 可选：是否开启思考模式，默认关闭（0/1）
AI_ENABLE_THINKING=0

# 可选：仅 responses 请求使用，优先级高于 AI_ENABLE_THINKING
# 可选值：none / minimal / low / medium / high
# AI_REASONING_EFFORT=medium

# 浏览器类型（chromium / webkit / firefox）
# Windows 默认使用 chromium
# BROWSER_TYPE=chromium

# 浏览器通道（常用可选值：msedge / chrome / 空值）
# Windows 默认使用系统自带 Edge，因此通常无需额外安装 Playwright Chromium
# 想改用 Chrome 时可设置为 chrome
# 使用 webkit / firefox 时请留空
# BROWSER_CHANNEL=msedge

# 可选：控制台输出 DEBUG 日志（0/1）
# DEBUG_MODE=1

# 可选：隐藏启动横幅（0/1），适合批量测试时减少输出噪音
# SUPPRESS_STARTUP_BANNER=1
