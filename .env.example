# 统一入口当前仅从 .env 读取 AI 配置。
# 复制本文件为 .env 后，再填入你自己的真实参数。

# 百炼 OpenAI 兼容模式 API 地址
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 百炼 API Key
DASHSCOPE_API_KEY=your_api_key_here

# 使用的模型名称
MODEL_NAME=qwen3.6-plus

# 可选：为 AI 考试启用百炼 Responses 联网搜索工具，默认关闭，需要时取消注释
# AI_ENABLE_WEB_SEARCH=1

# 浏览器类型（chromium / webkit / firefox）
# Windows 默认使用 chromium
# BROWSER_TYPE=chromium

# 浏览器通道（仅 chromium 类型常用）
# Windows 默认使用系统自带 Edge，因此通常无需额外安装 Playwright Chromium
# 想改用 Chrome 时可设置为 chrome
# 使用 webkit / firefox 时请留空
# BROWSER_CHANNEL=msedge

# 可选：控制台输出 DEBUG 日志
# DEBUG_MODE=1

# 可选：隐藏启动横幅，适合批量测试时减少输出噪音
# SUPPRESS_STARTUP_BANNER=1
